{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "kill-venue-port",
            "type": "shell",
            "command": "PIDS=$(lsof -tiTCP:5260 -sTCP:LISTEN); if [ -n \"$PIDS\" ]; then kill -9 $PIDS; fi",
            "problemMatcher": [],
            "presentation": {
                "reveal": "never"
            }
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/VenueTracker.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "prepare-debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "kill-venue-port",
                "build"
            ],
            "problemMatcher": []
        }
    ]
}