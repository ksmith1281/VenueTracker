@page "/add-show"
@rendermode InteractiveServer

@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>Add New Show</PageTitle>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Add New Show</RadzenText>

<RadzenCard class="rz-mb-4">
    <EditForm Model="@newShow" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <RadzenFormField Text="Venue" class="rz-w-100 rz-mb-4">
            <RadzenDropDown TValue="int" Data="venues" TextProperty="DisplayName" ValueProperty="VenueId"
                            @bind-Value="newShow.VenueId" Placeholder="Select venue" Style="width: 100%;" />
        </RadzenFormField>

        <RadzenFormField Text="Show Date" class="rz-w-100 rz-mb-4">
            <RadzenDatePicker TValue="DateTime" @bind-Value="newShow.ShowDate" DateFormat="MM/dd/yyyy"
                              Style="width: 100%;" />
        </RadzenFormField>

        <RadzenFormField Text="Deal" class="rz-w-100 rz-mb-4">
            <RadzenTextBox @bind-Value="newShow.Deal" Style="width: 100%;" />
        </RadzenFormField>

        <RadzenFormField Text="Show Name (Optional)" class="rz-w-100 rz-mb-4">
            <RadzenTextBox @bind-Value="newShow.ShowName" Style="width: 100%;" />
        </RadzenFormField>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8px">
            <RadzenButton ButtonType="ButtonType.Submit" Text="Add Show" Icon="add_circle"
                          ButtonStyle="ButtonStyle.Primary" />
            <RadzenButton Text="Add Venue" Icon="location_city" ButtonStyle="ButtonStyle.Light" Click="AddVenue"
                          ButtonType="ButtonType.Button" />
            <RadzenButton Text="Cancel" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="Cancel"
                          ButtonType="ButtonType.Button" />
        </RadzenStack>
    </EditForm>
</RadzenCard>

<RadzenCard>
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">Recent Shows</RadzenText>
    <RadzenDataGrid Data="recentShows" TItem="tShow" AllowSorting="false"
                    RowClick="@((DataGridRowMouseEventArgs<tShow> e) => NavigateToEdit(e.Data.ShowId))" Style="cursor: pointer;">
        <Columns>
            <RadzenDataGridColumn TItem="tShow" Property="ShowDate" Title="Date" FormatString="{0:d}" />
            <RadzenDataGridColumn TItem="tShow" Title="Show Name">
                <Template Context="show">
                    @(show.ShowName ?? $"Show on {show.ShowDate.ToShortDateString()}")
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="tShow" Title="Venue">
                <Template Context="show">
                    @show.tVenue?.VenueName (@show.tVenue?.City, @show.tVenue?.State)
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@code {
    private tShow newShow = new() { ShowDate = DateTime.Today };
    private List<VenueOption> venues = new();
    private List<tShow> recentShows = new();

    protected override void OnInitialized()
    {
        LoadVenues();
        LoadRecentShows();
    }

    private void LoadVenues()
    {
        venues = Db.tVenues
            .Where(v => v.IsActive)
            .OrderBy(v => v.VenueName)
            .Select(v => new VenueOption
            {
                VenueId = v.VenueId,
                DisplayName = v.VenueName + " (" + v.City + ", " + v.State + ")"
            })
            .ToList();
    }

    private void LoadRecentShows()
    {
        recentShows = Db.tShows
            .Include(s => s.tVenue)
            .OrderByDescending(s => s.CreatedOn)
            .Take(10)
            .ToList();
    }

    private void HandleValidSubmit()
    {
        if (newShow.VenueId <= 0) return;

        var pendingStatus = Db.tStatuses.FirstOrDefault(s => s.StatusName == "Pending");
        if (pendingStatus == null)
        {
            pendingStatus = new tStatus { StatusName = "Pending" };
            Db.tStatuses.Add(pendingStatus);
            Db.SaveChanges();
        }

        newShow.StatusId = pendingStatus.StatusId;
        newShow.CreatedOn = DateTime.Now;
        newShow.UpdatedOn = DateTime.Now;

        Db.tShows.Add(newShow);
        Db.SaveChanges();

        Navigation.NavigateTo("/");
    }

    private void NavigateToEdit(int showId)
    {
        Navigation.NavigateTo($"/edit-show/{showId}");
    }

    private void AddVenue()
    {
        Navigation.NavigateTo("/venues");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/");
    }

    private class VenueOption
    {
        public int VenueId { get; set; }
        public string DisplayName { get; set; } = string.Empty;
    }
}
