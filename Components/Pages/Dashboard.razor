@page "/"
@rendermode InteractiveServer
@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Navigation
@inject ILogger<Dashboard> Logger

<PageTitle>Dashboard</PageTitle>

<MudCard Class="my-4">
    <MudCardContent>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <MudText Typo="Typo.h4">Shows</MudText>

            <div class="d-flex align-items-center" style="gap: 12px;">
                <MudSelect T="int" Label="Year" @bind-Value="selectedYear" @bind-Value:after="OnYearChanged" Dense="true"
                           Variant="MudBlazor.Variant.Outlined" Style="min-width: 120px;">
                    @foreach (var year in availableYears)
                    {
                        <MudSelectItem T="int" Value="@year">@year</MudSelectItem>
                    }
                </MudSelect>

                <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" OnClick="AddShow">
                    Add Show
                </MudButton>
            </div>
        </div>

        <MudText Typo="Typo.body1" Class="mb-3">Shows for @selectedYear</MudText>

        @if (currentYearShows.Count == 0)
        {
            <MudText Typo="Typo.subtitle1">No shows found for @selectedYear.</MudText>
        }
        else
        {
            <MudTable T="ShowView" Items="currentYearShows" Hover="true" Bordered="true" Striped="true" Dense="true"
                      OnRowClick="@((TableRowClickEventArgs<ShowView> e) => { if (e.Item is not null) EditShow(e.Item.ShowId); })">
                <HeaderContent>
                    <MudTh>Show Date</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Show Name</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Show Date">@context.ShowDate.ToShortDateString()</MudTd>
                    <MudTd DataLabel="Status">@context.StatusName</MudTd>
                    <MudTd DataLabel="Show Name">@context.ShowName</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    private List<ShowView> currentYearShows = new();
    private List<int> availableYears = new();
    private int selectedYear;

    protected override void OnInitialized()
    {
        selectedYear = DateTime.Now.Year;

        var currentYear = DateTime.Now.Year;
        availableYears = Enumerable.Range(currentYear - 5, 11)
            .OrderByDescending(y => y)
            .ToList();

        LoadData();
    }

    private void LoadData()
    {
        var startOfYear = new DateTime(selectedYear, 1, 1);
        var endOfYear = new DateTime(selectedYear, 12, 31);

        currentYearShows = Db.tShows
            .Include(s => s.tStatus)
            .Where(s => s.ShowDate >= startOfYear && s.ShowDate <= endOfYear)
            .OrderBy(s => s.ShowDate)
            .Select(s => new ShowView
            {
                ShowId = s.ShowId,
                ShowDate = s.ShowDate,
                ShowName = s.ShowName,
                StatusName = s.tStatus != null ? s.tStatus.StatusName : null
            })
            .ToList();
    }

    private void OnYearChanged()
    {
        LoadData();
    }

    private void EditShow(int showId)
    {
        Logger.LogInformation("EditShow called with showId: {ShowId}", showId);
        Console.WriteLine($"DEBUG: EditShow called with showId: {showId}");
        Navigation.NavigateTo($"/edit-show/{showId}");
    }

    private void AddShow()
    {
        Navigation.NavigateTo("/add-show");
    }

    private class ShowView
    {
        public int ShowId { get; set; }
        public DateTime ShowDate { get; set; }
        public string? ShowName { get; set; }
        public string? StatusName { get; set; }
    }
}