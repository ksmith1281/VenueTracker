@page "/"
@rendermode InteractiveServer
@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Navigation
@inject ILogger<Dashboard> Logger

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>
<p>Shows for @DateTime.Now.Year</p>

@if (currentYearShows.Count == 0)
{
    <p>No shows found for @DateTime.Now.Year.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Show Date</th>
                <th>Status</th>
                <th>Show Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var show in currentYearShows)
            {
                <tr @onclick="() => EditShow(show.ShowId)" style="cursor: pointer;">
                    <td>@show.ShowDate.ToShortDateString()</td>
                    <td>@show.StatusName</td>
                    <td>@show.ShowName</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ShowView> currentYearShows = new();

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        var currentYear = DateTime.Now.Year;
        var startOfYear = new DateTime(currentYear, 1, 1);
        var endOfYear = new DateTime(currentYear, 12, 31);

        currentYearShows = Db.tShows
            .Include(s => s.tVenue)
            .Include(s => s.tStatus)
            .Where(s => s.ShowDate >= startOfYear && s.ShowDate <= endOfYear)
            .OrderBy(s => s.ShowDate)
            .Select(s => new ShowView
            {
                ShowId = s.ShowId,
                ShowDate = s.ShowDate,
                ShowName = s.ShowName,
                StatusName = s.tStatus!.StatusName
            })
            .ToList();
    }

    private void EditShow(int showId)
    {
        Logger.LogInformation($"EditShow called with showId: {showId}");
        Console.WriteLine($"DEBUG: EditShow called with showId: {showId}");
        Navigation.NavigateTo($"/edit-show/{showId}");
    }

    private class ShowView
    {
        public int ShowId { get; set; }
        public DateTime ShowDate { get; set; }
        public string? ShowName { get; set; }
        public string? StatusName { get; set; }
    }
}
