@page "/"
@rendermode InteractiveServer
@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Navigation
@inject ILogger<Dashboard> Logger

<PageTitle>Dashboard</PageTitle>

<RadzenCard class="rz-my-4">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="rz-mb-4">
        <RadzenText TextStyle="TextStyle.H5">Shows</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="12px">
            <RadzenDropDown TValue="int" Data="availableYears" @bind-Value="selectedYear" Change="OnYearChanged"
                            Style="min-width: 100px;" />
            <RadzenButton Text="Add Show" Icon="add_circle" ButtonStyle="ButtonStyle.Primary" Click="AddShow" />
        </RadzenStack>
    </RadzenStack>

    <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-3">Shows for @selectedYear</RadzenText>

    @if (currentYearShows.Count == 0)
    {
        <RadzenText TextStyle="TextStyle.Subtitle1">No shows found for @selectedYear.</RadzenText>
    }
    else
    {
        <RadzenDataGrid Data="currentYearShows" TItem="ShowView" AllowSorting="true"
                        RowClick="OnShowRowClick"
                        Style="cursor: pointer;">
            <Columns>
                <RadzenDataGridColumn TItem="ShowView" Property="ShowDate" Title="Show Date" FormatString="{0:d}" />
                <RadzenDataGridColumn TItem="ShowView" Property="StatusName" Title="Status" />
                <RadzenDataGridColumn TItem="ShowView" Property="ShowName" Title="Show Name" />
            </Columns>
        </RadzenDataGrid>
    }
</RadzenCard>

@code {
    private List<ShowView> currentYearShows = new();
    private List<int> availableYears = new();
    private int selectedYear;

    protected override void OnInitialized()
    {
        selectedYear = DateTime.Now.Year;

        var currentYear = DateTime.Now.Year;
        availableYears = Enumerable.Range(currentYear - 5, 11)
            .OrderByDescending(y => y)
            .ToList();

        LoadData();
    }

    private void LoadData()
    {
        var startOfYear = new DateTime(selectedYear, 1, 1);
        var endOfYear = new DateTime(selectedYear, 12, 31);

        currentYearShows = Db.tShows
            .Include(s => s.tStatus)
            .Where(s => s.ShowDate >= startOfYear && s.ShowDate <= endOfYear)
            .OrderBy(s => s.ShowDate)
            .Select(s => new ShowView
            {
                ShowId = s.ShowId,
                ShowDate = s.ShowDate,
                ShowName = s.ShowName,
                StatusName = s.tStatus != null ? s.tStatus.StatusName : null
            })
            .ToList();
    }

    private void OnYearChanged()
    {
        LoadData();
    }

    private void EditShow(int showId)
    {
        Navigation.NavigateTo($"/edit-show/{showId}");
    }

    private void OnShowRowClick(DataGridRowMouseEventArgs<ShowView> args)
    {
        if (args.Data != null) EditShow(args.Data.ShowId);
    }

    private void AddShow()
    {
        Navigation.NavigateTo("/add-show");
    }

    private class ShowView
    {
        public int ShowId { get; set; }
        public DateTime ShowDate { get; set; }
        public string? ShowName { get; set; }
        public string? StatusName { get; set; }
    }
}
