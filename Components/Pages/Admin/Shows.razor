@page "/admin/shows"
@rendermode InteractiveServer

@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<h3>Shows</h3>

<EditForm Model="@currentShow" OnValidSubmit="@HandleValidSubmit" FormName="ShowForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="venue" class="form-label">Venue</label>
        <select id="venue" class="form-select" @bind="currentShow.VenueId">
            <option value="0">Select venue</option>
            @foreach (var venue in venues)
            {
                <option value="@venue.VenueId">@venue.VenueName (@venue.City, @venue.State)</option>
            }
        </select>
        <ValidationMessage For="@(() => currentShow.VenueId)" />
    </div>

    <div class="mb-3">
        <label for="showDate" class="form-label">Show Date</label>
        <InputDate id="showDate" class="form-control" @bind-Value="currentShow.ShowDate" />
        <ValidationMessage For="@(() => currentShow.ShowDate)" />
    </div>

    <div class="mb-3">
        <label for="status" class="form-label">Status</label>
        <select id="status" class="form-select" @bind="currentShow.StatusId">
            <option value="0">Select status</option>
            @foreach (var status in statuses)
            {
                <option value="@status.StatusId">@status.StatusName</option>
            }
        </select>
        <ValidationMessage For="@(() => currentShow.StatusId)" />
    </div>

    <div class="mb-3">
        <label for="walkAmount" class="form-label">Walk Amount</label>
        <InputNumber id="walkAmount" class="form-control" @bind-Value="currentShow.WalkAmount" />
    </div>

    <div class="mb-3">
        <label for="merchAmount" class="form-label">Merch Amount</label>
        <InputNumber id="merchAmount" class="form-control" @bind-Value="currentShow.MerchAmount" />
    </div>

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea id="notes" class="form-control" @bind-Value="currentShow.Notes" />
    </div>

    <button type="submit" class="btn btn-primary">@(isEditMode ? "Save Show" : "Add Show")</button>
    <button type="button" class="btn btn-secondary ms-2" @onclick="ResetForm">Cancel</button>
</EditForm>

<hr />

<h4>Show List</h4>

@if (shows.Count == 0)
{
    <p>No shows available.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ShowId</th>
                <th>VenueId</th>
                <th>ShowDate</th>
                <th>ShowName</th>
                <th>Status</th>
                <th>WalkAmount</th>
                <th>MerchAmount</th>
                <th>Notes</th>
                <th>CreatedOn</th>
                <th>UpdatedOn</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var show in shows)
            {
                <tr>
                    <td>@show.ShowId</td>
                    <td>@show.VenueId</td>
                    <td>@show.ShowDate.ToShortDateString()</td>
                    <td>@show.ShowName</td>
                    <td>@show.tStatus?.StatusName</td>
                    <td>@show.WalkAmount</td>
                    <td>@show.MerchAmount</td>
                    <td>@show.Notes</td>
                    <td>@show.CreatedOn</td>
                    <td>@show.UpdatedOn</td>
                    <td>
                        <button class="btn btn-sm btn-secondary me-1" @onclick="() => EditShow(show)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteShow(show.ShowId)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private tShow currentShow = new() { ShowDate = DateTime.Today };
    private List<tShow> shows = new();
    private List<tVenue> venues = new();
    private List<tStatus> statuses = new();
    private bool isEditMode = false;

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        venues = Db.tVenues
            .Where(v => v.IsActive)
            .OrderBy(v => v.VenueName)
            .ToList();

        statuses = Db.tStatuses
            .OrderBy(s => s.StatusName)
            .ToList();

        shows = Db.tShows
            .Include(s => s.tVenue)
            .Include(s => s.tStatus)
            .OrderByDescending(s => s.ShowDate)
            .ToList();
    }

    private void HandleValidSubmit()
    {
        if (currentShow.VenueId <= 0 || currentShow.StatusId <= 0)
        {
            return; // invalid selection
        }

        if (isEditMode)
        {
            var showFromDb = Db.tShows.FirstOrDefault(s => s.ShowId == currentShow.ShowId);
            if (showFromDb != null)
            {
                showFromDb.VenueId = currentShow.VenueId;
                showFromDb.ShowDate = currentShow.ShowDate;
                showFromDb.ShowName = currentShow.ShowName;
                showFromDb.StatusId = currentShow.StatusId;
                showFromDb.WalkAmount = currentShow.WalkAmount;
                showFromDb.MerchAmount = currentShow.MerchAmount;
                showFromDb.Notes = currentShow.Notes;
                showFromDb.UpdatedOn = DateTime.Now;

                Db.SaveChanges();
            }
        }
        else
        {
            var newShow = new tShow
            {
                VenueId = currentShow.VenueId,
                ShowDate = currentShow.ShowDate,
                ShowName = currentShow.ShowName,
                StatusId = currentShow.StatusId,
                WalkAmount = currentShow.WalkAmount,
                MerchAmount = currentShow.MerchAmount,
                Notes = currentShow.Notes,
                CreatedOn = DateTime.Now,
                UpdatedOn = DateTime.Now
            };

            Db.tShows.Add(newShow);
            Db.SaveChanges();
        }

        LoadData();
        ResetForm();
    }

    private void EditShow(tShow show)
    {
        currentShow = new tShow
        {
            ShowId = show.ShowId,
            VenueId = show.VenueId,
            ShowDate = show.ShowDate,
            ShowName = show.ShowName,
            StatusId = show.StatusId,
            WalkAmount = show.WalkAmount,
            MerchAmount = show.MerchAmount,
            Notes = show.Notes,
            CreatedOn = show.CreatedOn,
            UpdatedOn = show.UpdatedOn
        };

        isEditMode = true;
    }

    private void DeleteShow(int showId)
    {
        var show = Db.tShows.FirstOrDefault(s => s.ShowId == showId);
        if (show != null)
        {
            Db.tShows.Remove(show);
            Db.SaveChanges();
            LoadData();
            ResetForm();
        }
    }

    private void ResetForm()
    {
        currentShow = new tShow { ShowDate = DateTime.Today };
        isEditMode = false;
    }
}