@page "/admin/shows"
@rendermode InteractiveServer

@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<PageTitle>Admin - Shows</PageTitle>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Shows</RadzenText>

<RadzenCard class="rz-mb-4">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">@(isEditMode ? "Edit Show" : "Add Show")</RadzenText>
    <EditForm Model="@currentShow" OnValidSubmit="@HandleValidSubmit" FormName="ShowForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <RadzenFormField Text="Venue" class="rz-w-100 rz-mb-4">
            <RadzenDropDown TValue="int" Data="venues" TextProperty="DisplayName" ValueProperty="VenueId"
                            @bind-Value="currentShow.VenueId" Placeholder="Select venue" Style="width: 100%;" />
        </RadzenFormField>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-4" Wrap="FlexWrap.Wrap">
            <RadzenFormField Text="Show Date" Style="flex: 1;">
                <RadzenDatePicker TValue="DateTime" @bind-Value="currentShow.ShowDate" DateFormat="MM/dd/yyyy" Style="width: 100%;" />
            </RadzenFormField>
            <RadzenFormField Text="Status" Style="flex: 1;">
                <RadzenDropDown TValue="int" Data="statuses" TextProperty="StatusName" ValueProperty="StatusId"
                                @bind-Value="currentShow.StatusId" Placeholder="Select status" Style="width: 100%;" />
            </RadzenFormField>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-4" Wrap="FlexWrap.Wrap">
            <RadzenFormField Text="Walk Amount" Style="flex: 1;">
                <RadzenNumeric TValue="decimal" @bind-Value="currentShow.WalkAmount" Format="C" Style="width: 100%;" />
            </RadzenFormField>
            <RadzenFormField Text="Merch Amount" Style="flex: 1;">
                <RadzenNumeric TValue="decimal?" @bind-Value="currentShow.MerchAmount" Format="C" Style="width: 100%;" />
            </RadzenFormField>
        </RadzenStack>

        <RadzenFormField Text="Notes" class="rz-w-100 rz-mb-4">
            <RadzenTextArea @bind-Value="currentShow.Notes" Rows="3" Style="width: 100%;" />
        </RadzenFormField>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8px">
            <RadzenButton ButtonType="ButtonType.Submit" Text="@(isEditMode ? "Save Show" : "Add Show")"
                          Icon="save" ButtonStyle="ButtonStyle.Primary" />
            <RadzenButton Text="Cancel" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="ResetForm" ButtonType="ButtonType.Button" />
        </RadzenStack>
    </EditForm>
</RadzenCard>

<RadzenCard>
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">Show List</RadzenText>
    @if (shows.Count == 0)
    {
        <RadzenText>No shows available.</RadzenText>
    }
    else
    {
        <RadzenDataGrid Data="shows" TItem="tShow" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="tShow" Property="ShowId" Title="ID" Width="60px" />
                <RadzenDataGridColumn TItem="tShow" Property="ShowDate" Title="Date" FormatString="{0:d}" />
                <RadzenDataGridColumn TItem="tShow" Property="ShowName" Title="Show Name" />
                <RadzenDataGridColumn TItem="tShow" Title="Venue">
                    <Template Context="s">@s.tVenue?.VenueName</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="tShow" Title="Status">
                    <Template Context="s">@s.tStatus?.StatusName</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="tShow" Property="WalkAmount" Title="Walk" FormatString="{0:C}" />
                <RadzenDataGridColumn TItem="tShow" Property="MerchAmount" Title="Merch" FormatString="{0:C}" />
                <RadzenDataGridColumn TItem="tShow" Property="Notes" Title="Notes" />
                <RadzenDataGridColumn TItem="tShow" Title="Actions" Width="120px">
                    <Template Context="s">
                        <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      Click="@((MouseEventArgs _) => EditShow(s))" class="rz-mr-1" />
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                      Click="@((MouseEventArgs _) => DeleteShow(s.ShowId))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
</RadzenCard>

@code {
    private tShow currentShow = new() { ShowDate = DateTime.Today };
    private List<tShow> shows = new();
    private List<VenueOption> venues = new();
    private List<tStatus> statuses = new();
    private bool isEditMode = false;

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        venues = Db.tVenues
            .Where(v => v.IsActive)
            .OrderBy(v => v.VenueName)
            .Select(v => new VenueOption
            {
                VenueId = v.VenueId,
                DisplayName = v.VenueName + " (" + v.City + ", " + v.State + ")"
            })
            .ToList();

        statuses = Db.tStatuses
            .OrderBy(s => s.StatusName)
            .ToList();

        shows = Db.tShows
            .Include(s => s.tVenue)
            .Include(s => s.tStatus)
            .OrderByDescending(s => s.ShowDate)
            .ToList();
    }

    private void HandleValidSubmit()
    {
        if (currentShow.VenueId <= 0 || currentShow.StatusId <= 0) return;

        if (isEditMode)
        {
            var showFromDb = Db.tShows.FirstOrDefault(s => s.ShowId == currentShow.ShowId);
            if (showFromDb != null)
            {
                showFromDb.VenueId = currentShow.VenueId;
                showFromDb.ShowDate = currentShow.ShowDate;
                showFromDb.ShowName = currentShow.ShowName;
                showFromDb.StatusId = currentShow.StatusId;
                showFromDb.WalkAmount = currentShow.WalkAmount;
                showFromDb.MerchAmount = currentShow.MerchAmount;
                showFromDb.Notes = currentShow.Notes;
                showFromDb.UpdatedOn = DateTime.Now;
                Db.SaveChanges();
            }
        }
        else
        {
            Db.tShows.Add(new tShow
            {
                VenueId = currentShow.VenueId,
                ShowDate = currentShow.ShowDate,
                ShowName = currentShow.ShowName,
                StatusId = currentShow.StatusId,
                WalkAmount = currentShow.WalkAmount,
                MerchAmount = currentShow.MerchAmount,
                Notes = currentShow.Notes,
                CreatedOn = DateTime.Now,
                UpdatedOn = DateTime.Now
            });
            Db.SaveChanges();
        }

        LoadData();
        ResetForm();
    }

    private void EditShow(tShow show)
    {
        currentShow = new tShow
        {
            ShowId = show.ShowId,
            VenueId = show.VenueId,
            ShowDate = show.ShowDate,
            ShowName = show.ShowName,
            StatusId = show.StatusId,
            WalkAmount = show.WalkAmount,
            MerchAmount = show.MerchAmount,
            Notes = show.Notes,
            CreatedOn = show.CreatedOn,
            UpdatedOn = show.UpdatedOn
        };
        isEditMode = true;
    }

    private void DeleteShow(int showId)
    {
        var show = Db.tShows.FirstOrDefault(s => s.ShowId == showId);
        if (show != null)
        {
            Db.tShows.Remove(show);
            Db.SaveChanges();
            LoadData();
            ResetForm();
        }
    }

    private void ResetForm()
    {
        currentShow = new tShow { ShowDate = DateTime.Today };
        isEditMode = false;
    }

    private class VenueOption
    {
        public int VenueId { get; set; }
        public string DisplayName { get; set; } = string.Empty;
    }
}
