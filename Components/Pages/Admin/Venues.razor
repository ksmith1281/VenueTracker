@page "/admin/venues"
@rendermode InteractiveServer

@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<h3>Venues</h3>

<EditForm Model="@currentVenue" OnValidSubmit="@HandleValidSubmit" FormName="VenueForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="venueName" class="form-label">Venue Name</label>
        <InputText id="venueName" class="form-control" @bind-Value="currentVenue.VenueName" />
        <ValidationMessage For="@(() => currentVenue.VenueName)" />
    </div>

    <div class="mb-3">
        <label for="city" class="form-label">City</label>
        <InputText id="city" class="form-control" @bind-Value="currentVenue.City" />
        <ValidationMessage For="@(() => currentVenue.City)" />
    </div>

    <div class="mb-3">
        <label for="state" class="form-label">State</label>
        <InputText id="state" class="form-control" @bind-Value="currentVenue.State" />
        <ValidationMessage For="@(() => currentVenue.State)" />
    </div>

    <div class="form-check mb-3">
        <InputCheckbox id="isActive" class="form-check-input" @bind-Value="currentVenue.IsActive" />
        <label for="isActive" class="form-check-label">Active</label>
    </div>

    <button type="submit" class="btn btn-primary">
        @(isEditMode ? "Save Changes" : "Add Venue")
    </button>

    <button type="button" class="btn btn-secondary ms-2" @onclick="ResetForm">
        Cancel
    </button>
</EditForm>

<hr />

<h4>Venue List</h4>

@if (venues.Count == 0)
{
    <p>No venues added yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>VenueId</th>
                <th>VenueName</th>
                <th>City</th>
                <th>State</th>
                <th>IsActive</th>
                <th>CreatedOn</th>
                <th>UpdatedOn</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var venue in venues)
            {
                <tr>
                    <td>@venue.VenueId</td>
                    <td>@venue.VenueName</td>
                    <td>@venue.City</td>
                    <td>@venue.State</td>
                    <td>@venue.IsActive</td>
                    <td>@venue.CreatedOn</td>
                    <td>@venue.UpdatedOn</td>
                    <td>
                        <button type="button" class="btn btn-sm btn-secondary me-1"
                                @onclick="() => EditVenue(venue)">Edit</button>
                        <button type="button" class="btn btn-sm btn-danger"
                                @onclick="() => DeleteVenue(venue.VenueId)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private tVenue currentVenue = new() { IsActive = true };

    private List<tVenue> venues = new();

    private bool isEditMode = false;

    protected override void OnInitialized()
    {
        LoadVenues();
    }

    private void LoadVenues()
    {
        venues = Db.tVenues
            .OrderBy(v => v.VenueName)
            .ToList();
    }

    private void HandleValidSubmit()
    {
        if (isEditMode)
        {
            var venueToUpdate = Db.tVenues.FirstOrDefault(v => v.VenueId == currentVenue.VenueId);

            if (venueToUpdate is not null)
            {
                venueToUpdate.VenueName = currentVenue.VenueName;
                venueToUpdate.City = currentVenue.City;
                venueToUpdate.State = currentVenue.State;
                venueToUpdate.IsActive = currentVenue.IsActive;
                venueToUpdate.UpdatedOn = DateTime.Now;

                Db.SaveChanges();
            }
        }
        else
        {
            var venueToAdd = new tVenue
            {
                VenueName = currentVenue.VenueName,
                City = currentVenue.City,
                State = currentVenue.State,
                IsActive = currentVenue.IsActive,
                CreatedOn = DateTime.Now,
                UpdatedOn = DateTime.Now
            };

            Db.tVenues.Add(venueToAdd);
            Db.SaveChanges();
        }

        LoadVenues();
        ResetForm();
    }

    private void EditVenue(tVenue venue)
    {
        currentVenue = new tVenue
        {
            VenueId = venue.VenueId,
            VenueName = venue.VenueName,
            City = venue.City,
            State = venue.State,
            IsActive = venue.IsActive,
            CreatedOn = venue.CreatedOn,
            UpdatedOn = venue.UpdatedOn
        };

        isEditMode = true;
    }

    private void DeleteVenue(int venueId)
    {
        var venue = Db.tVenues.FirstOrDefault(v => v.VenueId == venueId);
        if (venue != null)
        {
            Db.tVenues.Remove(venue);
            Db.SaveChanges();
            LoadVenues();
            ResetForm();
        }
    }

    private void ResetForm()
    {
        currentVenue = new tVenue
        {
            IsActive = true
        };

        isEditMode = false;
    }
}