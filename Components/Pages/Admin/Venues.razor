@page "/admin/venues"
@rendermode InteractiveServer

@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<PageTitle>Admin - Venues</PageTitle>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Venues</RadzenText>

<RadzenCard class="rz-mb-4">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">@(isEditMode ? "Edit Venue" : "Add Venue")</RadzenText>
    <EditForm Model="@currentVenue" OnValidSubmit="@HandleValidSubmit" FormName="VenueForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <RadzenFormField Text="Venue Name" class="rz-w-100 rz-mb-4">
            <RadzenTextBox @bind-Value="currentVenue.VenueName" Style="width: 100%;" />
        </RadzenFormField>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-4" Wrap="FlexWrap.Wrap">
            <RadzenFormField Text="City" Style="flex: 1;">
                <RadzenTextBox @bind-Value="currentVenue.City" Style="width: 100%;" />
            </RadzenFormField>
            <RadzenFormField Text="State" Style="flex: 1;">
                <RadzenTextBox @bind-Value="currentVenue.State" Style="width: 100%;" />
            </RadzenFormField>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" class="rz-mb-4">
            <RadzenCheckBox TValue="bool" @bind-Value="currentVenue.IsActive" />
            <RadzenLabel Text="Active" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8px">
            <RadzenButton ButtonType="ButtonType.Submit" Text="@(isEditMode ? "Save Changes" : "Add Venue")"
                          Icon="save" ButtonStyle="ButtonStyle.Primary" />
            <RadzenButton Text="Cancel" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="ResetForm" ButtonType="ButtonType.Button" />
        </RadzenStack>
    </EditForm>
</RadzenCard>

<RadzenCard>
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">Venue List</RadzenText>
    @if (venues.Count == 0)
    {
        <RadzenText>No venues added yet.</RadzenText>
    }
    else
    {
        <RadzenDataGrid Data="venues" TItem="tVenue" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="tVenue" Property="VenueId" Title="ID" Width="60px" />
                <RadzenDataGridColumn TItem="tVenue" Property="VenueName" Title="Venue Name" />
                <RadzenDataGridColumn TItem="tVenue" Property="City" Title="City" />
                <RadzenDataGridColumn TItem="tVenue" Property="State" Title="State" />
                <RadzenDataGridColumn TItem="tVenue" Title="Active">
                    <Template Context="v">@(v.IsActive ? "Yes" : "No")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="tVenue" Property="CreatedOn" Title="Created" FormatString="{0:d}" />
                <RadzenDataGridColumn TItem="tVenue" Property="UpdatedOn" Title="Updated" FormatString="{0:d}" />
                <RadzenDataGridColumn TItem="tVenue" Title="Actions" Width="120px">
                    <Template Context="v">
                        <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      Click="() => EditVenue(v)" class="rz-mr-1" />
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                      Click="() => DeleteVenue(v.VenueId)" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
</RadzenCard>

@code {
    private tVenue currentVenue = new() { IsActive = true };
    private List<tVenue> venues = new();
    private bool isEditMode = false;

    protected override void OnInitialized()
    {
        LoadVenues();
    }

    private void LoadVenues()
    {
        venues = Db.tVenues
            .OrderBy(v => v.VenueName)
            .ToList();
    }

    private void HandleValidSubmit()
    {
        if (isEditMode)
        {
            var venueToUpdate = Db.tVenues.FirstOrDefault(v => v.VenueId == currentVenue.VenueId);
            if (venueToUpdate is not null)
            {
                venueToUpdate.VenueName = currentVenue.VenueName;
                venueToUpdate.City = currentVenue.City;
                venueToUpdate.State = currentVenue.State;
                venueToUpdate.IsActive = currentVenue.IsActive;
                venueToUpdate.UpdatedOn = DateTime.Now;
                Db.SaveChanges();
            }
        }
        else
        {
            Db.tVenues.Add(new tVenue
            {
                VenueName = currentVenue.VenueName,
                City = currentVenue.City,
                State = currentVenue.State,
                IsActive = currentVenue.IsActive,
                CreatedOn = DateTime.Now,
                UpdatedOn = DateTime.Now
            });
            Db.SaveChanges();
        }

        LoadVenues();
        ResetForm();
    }

    private void EditVenue(tVenue venue)
    {
        currentVenue = new tVenue
        {
            VenueId = venue.VenueId,
            VenueName = venue.VenueName,
            City = venue.City,
            State = venue.State,
            IsActive = venue.IsActive,
            CreatedOn = venue.CreatedOn,
            UpdatedOn = venue.UpdatedOn
        };
        isEditMode = true;
    }

    private void DeleteVenue(int venueId)
    {
        var venue = Db.tVenues.FirstOrDefault(v => v.VenueId == venueId);
        if (venue != null)
        {
            Db.tVenues.Remove(venue);
            Db.SaveChanges();
            LoadVenues();
            ResetForm();
        }
    }

    private void ResetForm()
    {
        currentVenue = new tVenue { IsActive = true };
        isEditMode = false;
    }
}
