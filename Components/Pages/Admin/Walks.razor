@page "/admin/walks"
@rendermode InteractiveServer

@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<h3>Walks</h3>

<EditForm Model="@currentWalk" OnValidSubmit="@HandleValidSubmit" FormName="WalkForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="show" class="form-label">Show</label>
        <select id="show" class="form-select" @bind="currentWalk.ShowId">
            <option value="0">Select show</option>
            @foreach (var show in shows)
            {
                <option value="@show.ShowId">@show.ShowId - @show.ShowDate.ToShortDateString() - @show.ShowName</option>
            }
        </select>
        <ValidationMessage For="@(() => currentWalk.ShowId)" />
    </div>

    <div class="mb-3">
        <label for="walkAmount" class="form-label">Walk Amount</label>
        <InputNumber id="walkAmount" class="form-control" @bind-Value="currentWalk.WalkAmount" />
        <ValidationMessage For="@(() => currentWalk.WalkAmount)" />
    </div>

    <div class="mb-3">
        <label for="merchAmount" class="form-label">Merch Amount</label>
        <InputNumber id="merchAmount" class="form-control" @bind-Value="currentWalk.MerchAmount" />
    </div>

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea id="notes" class="form-control" @bind-Value="currentWalk.Notes" />
    </div>

    <button type="submit" class="btn btn-primary">@(isEditMode ? "Save Walk" : "Add Walk")</button>
    <button type="button" class="btn btn-secondary ms-2" @onclick="ResetForm">Cancel</button>
</EditForm>

<hr />

<h4>Walk List</h4>

@if (walks.Count == 0)
{
    <p>No walk records available.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>WalkId</th>
                <th>ShowId</th>
                <th>WalkAmount</th>
                <th>MerchAmount</th>
                <th>Notes</th>
                <th>CreatedOn</th>
                <th>UpdatedOn</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var walk in walks)
            {
                <tr>
                    <td>@walk.WalkId</td>
                    <td>@walk.ShowId</td>
                    <td>@walk.WalkAmount</td>
                    <td>@walk.MerchAmount</td>
                    <td>@walk.Notes</td>
                    <td>@walk.CreatedOn</td>
                    <td>@walk.UpdatedOn</td>
                    <td>
                        <button class="btn btn-sm btn-secondary me-1" @onclick="() => EditWalk(walk)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteWalk(walk.WalkId)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Walk currentWalk = new() { WalkAmount = 0m };
    private List<Walk> walks = new();
    private List<Show> shows = new();
    private bool isEditMode = false;

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        shows = Db.Shows
            .OrderBy(s => s.ShowDate)
            .ToList();

        walks = Db.Walks
            .OrderByDescending(w => w.CreatedOn)
            .ToList();
    }

    private void HandleValidSubmit()
    {
        if (currentWalk.ShowId <= 0)
        {
            return;
        }

        if (isEditMode)
        {
            var walkFromDb = Db.Walks.FirstOrDefault(w => w.WalkId == currentWalk.WalkId);
            if (walkFromDb != null)
            {
                walkFromDb.ShowId = currentWalk.ShowId;
                walkFromDb.WalkAmount = currentWalk.WalkAmount;
                walkFromDb.MerchAmount = currentWalk.MerchAmount;
                walkFromDb.Notes = currentWalk.Notes;
                walkFromDb.UpdatedOn = DateTime.Now;

                Db.SaveChanges();
            }
        }
        else
        {
            var newWalk = new Walk
            {
                ShowId = currentWalk.ShowId,
                WalkAmount = currentWalk.WalkAmount,
                MerchAmount = currentWalk.MerchAmount,
                Notes = currentWalk.Notes,
                CreatedOn = DateTime.Now,
                UpdatedOn = DateTime.Now
            };

            Db.Walks.Add(newWalk);
            Db.SaveChanges();
        }

        LoadData();
        ResetForm();
    }

    private void EditWalk(Walk walk)
    {
        currentWalk = new Walk
        {
            WalkId = walk.WalkId,
            ShowId = walk.ShowId,
            WalkAmount = walk.WalkAmount,
            MerchAmount = walk.MerchAmount,
            Notes = walk.Notes,
            CreatedOn = walk.CreatedOn,
            UpdatedOn = walk.UpdatedOn
        };

        isEditMode = true;
    }

    private void DeleteWalk(int walkId)
    {
        var walk = Db.Walks.FirstOrDefault(w => w.WalkId == walkId);
        if (walk != null)
        {
            Db.Walks.Remove(walk);
            Db.SaveChanges();
            LoadData();
            ResetForm();
        }
    }

    private void ResetForm()
    {
        currentWalk = new Walk { WalkAmount = 0m };
        isEditMode = false;
    }
}