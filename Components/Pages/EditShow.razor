@page "/edit-show/{showId:int}"
@rendermode InteractiveServer

@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Navigation
@inject ILogger<EditShow> Logger

<PageTitle>Show Detail</PageTitle>

<h1>Show Detail</h1>

@if (show == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <label for="showSelect" class="form-label">Show</label>
        <select id="showSelect" class="form-select" @bind="selectedShowId" @bind:event="onchange">
            <option value="0">Select show</option>
            @foreach (var option in showOptions)
            {
                <option value="@option.ShowId">@option.DisplayText</option>
            }
        </select>
    </div>

    <EditForm Model="@show" OnValidSubmit="@HandleValidSubmit" FormName="EditShowForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Venue</label>
                <p class="form-control-plaintext">@(show.tVenue?.VenueName) (@(show.tVenue?.City), @(show.tVenue?.State))
                </p>
            </div>
            <div class="col-md-6">
                <label class="form-label">Status</label>
                <p class="form-control-plaintext">@show.tStatus?.StatusName</p>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label for="walkAmount" class="form-label">Walk Amount</label>
                <InputNumber id="walkAmount" class="form-control" @bind-Value="show.WalkAmount" @bind-Value:format="C" />
            </div>
            <div class="col-md-6">
                <label for="paymentType" class="form-label">Payment Type</label>
                <select id="paymentType" class="form-select" @bind="show.PaymentTypeId">
                    <option value="">Select payment type</option>
                    @foreach (var paymentType in paymentTypes)
                    {
                        <option value="@paymentType.PaymentTypeId">@paymentType.PaymentType</option>
                    }
                </select>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label for="merchAmount" class="form-label">Merch Amount</label>
                <InputNumber id="merchAmount" class="form-control" @bind-Value="show.MerchAmount" @bind-Value:format="C" />
            </div>
        </div>

        <div class="mb-3">
            <label for="deal" class="form-label">Deal</label>
            <InputText id="deal" class="form-control" @bind-Value="show.Deal" />
        </div>

        <div class="mb-3">
            <label for="notes" class="form-label">Notes</label>
            <InputTextArea id="notes" class="form-control" @bind-Value="show.Notes" rows="3" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <button type="button" class="btn btn-danger" @onclick="DeleteShow">Delete Show</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </div>
    </EditForm>

    <div class="card mt-4">
        <div class="card-header">
            <h5 class="card-title mb-0">Subcontractors</h5>
        </div>
        <div class="card-body">
            @if (showSubcontractors.Count > 0)
            {
                <div class="mb-4">
                    <h6>Current Subcontractors</h6>
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Role</th>
                                <th>Amount</th>
                                <th>Notes</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var subContractor in showSubcontractors)
                            {
                                @if (editingSubcontractorId == subContractor.ShowSubcontractorId)
                                {
                                    <tr>
                                        <td>@subContractor.tSubcontractor?.Name</td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" @bind="editingRole" />
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" @bind="editingAmount"
                                                   step="0.01" />
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" @bind="editingNotes" />
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-success"
                                                    @onclick="() => SaveSubcontractorEdit(subContractor.ShowSubcontractorId)">Save</button>
                                            <button type="button" class="btn btn-sm btn-secondary" @onclick="CancelEdit">Cancel</button>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    <tr>
                                        <td>@subContractor.tSubcontractor?.Name</td>
                                        <td>@subContractor.tSubcontractor?.Role</td>
                                        <td>@subContractor.Amount.ToString("C")</td>
                                        <td>@subContractor.Notes</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-primary"
                                                    @onclick="() => EditSubcontractor(subContractor)">Edit</button>
                                            <button type="button" class="btn btn-sm btn-danger"
                                                    @onclick="() => DeleteShowSubcontractor(subContractor.ShowSubcontractorId)">Delete</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }

            <h6>Add Subcontractor</h6>
            <div class="row mb-3">
                <div class="col-md-4">
                    <label for="subcontractor" class="form-label">Subcontractor</label>
                    <select id="subcontractor" class="form-select" @bind="selectedSubcontractorId">
                        <option value="0">Select subcontractor</option>
                        @foreach (var subcontractor in subcontractors)
                        {
                            <option value="@subcontractor.SubcontractorId">@subcontractor.Name (@subcontractor.Role)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="subAmount" class="form-label">Amount @if (selectedSubcontractorId > 0) {
                        <span class="text-danger">*</span>
                    }
                </label>
                <input type="number" id="subAmount" class="form-control" @bind="newSubcontractorAmount" step="0.01" />
            </div>
            <div class="col-md-4">
                <label for="subNotes" class="form-label">Notes</label>
                <input type="text" id="subNotes" class="form-control" @bind="newSubcontractorNotes" />
            </div>
        </div>
        <button type="button" class="btn btn-sm btn-success" @onclick="AddSubcontractor"
                disabled="@(selectedSubcontractorId <= 0 || newSubcontractorAmount <= 0)">
            Add Subcontractor
        </button>
    </div>
</div>
}

@code {
    [Parameter]
    public int ShowId { get; set; }

    private tShow? show;
    private List<tVenue> venues = new();
    private List<tStatus> statuses = new();
    private List<tPaymentType> paymentTypes = new();
    private List<tSubcontractor> subcontractors = new();
    private List<tShowSubcontractor> showSubcontractors = new();
    private List<ShowOption> showOptions = new();

    private int selectedShowId
    {
        get => _selectedShowId;
        set
        {
            if (_selectedShowId != value)
            {
                _selectedShowId = value;
                LoadShowData();
            }
        }
    }

    private int _selectedShowId = 0;
    private int selectedSubcontractorId = 0;
    private decimal newSubcontractorAmount = 0;
    private string newSubcontractorNotes = string.Empty;

    private int editingSubcontractorId = 0;
    private string editingRole = string.Empty;
    private decimal editingAmount = 0;
    private string editingNotes = string.Empty;

    protected override void OnInitialized()
    {
        LoadReferenceData();
    }

    protected override void OnParametersSet()
    {
        selectedShowId = ShowId;
        LoadShowData();
    }

    private void LoadReferenceData()
    {
        venues = Db.tVenues
            .Where(v => v.IsActive)
            .OrderBy(v => v.VenueName)
            .ToList();

        statuses = Db.tStatuses
            .OrderBy(s => s.StatusName)
            .ToList();

        paymentTypes = Db.tPaymentTypes
            .OrderBy(pt => pt.PaymentType)
            .ToList();

        subcontractors = Db.tSubcontractors
            .Where(s => s.IsActive)
            .OrderBy(s => s.Name)
            .ToList();

        showOptions = Db.tShows
            .OrderBy(s => s.ShowDate)
            .ThenBy(s => s.ShowName)
            .Select(s => new ShowOption
            {
                ShowId = s.ShowId,
                DisplayText = s.ShowDate.ToString("d") + " - " + (s.ShowName ?? string.Empty)
            })
            .ToList();
    }

    private void LoadShowData()
    {
        show = Db.tShows
            .Include(s => s.tVenue)
            .Include(s => s.tStatus)
            .Include(s => s.tPaymentType)
            .FirstOrDefault(s => s.ShowId == selectedShowId);

        if (show != null)
        {
            showSubcontractors = Db.tShowSubcontractors
                .Include(ss => ss.tSubcontractor)
                .Where(ss => ss.ShowId == selectedShowId)
                .ToList();
        }
    }

    private void HandleValidSubmit()
    {
        if (show == null)
        {
            return;
        }

        show.UpdatedOn = DateTime.Now;
        Db.SaveChanges();
        Navigation.NavigateTo("/");
    }

    private void DeleteShow()
    {
        if (show != null)
        {
            Db.tShows.Remove(show);
            Db.SaveChanges();
            Navigation.NavigateTo("/");
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/");
    }

    private void AddSubcontractor()
    {
        if (selectedSubcontractorId <= 0 || newSubcontractorAmount <= 0 || show == null)
        {
            return;
        }

        var newShowSubcontractor = new tShowSubcontractor
        {
            ShowId = show.ShowId,
            SubcontractorId = selectedSubcontractorId,
            Amount = newSubcontractorAmount,
            Notes = newSubcontractorNotes
        };

        Db.tShowSubcontractors.Add(newShowSubcontractor);
        Db.SaveChanges();

        // Reload subcontractors and reset form
        LoadShowData();
        selectedSubcontractorId = 0;
        newSubcontractorAmount = 0;
        newSubcontractorNotes = string.Empty;
    }

    private void DeleteShowSubcontractor(int showSubcontractorId)
    {
        var subcontractor = Db.tShowSubcontractors.FirstOrDefault(ss => ss.ShowSubcontractorId == showSubcontractorId);
        if (subcontractor != null)
        {
            Db.tShowSubcontractors.Remove(subcontractor);
            Db.SaveChanges();
            LoadShowData();
        }
    }

    private void EditSubcontractor(tShowSubcontractor subcontractor)
    {
        editingSubcontractorId = subcontractor.ShowSubcontractorId;
        editingRole = subcontractor.tSubcontractor?.Role ?? string.Empty;
        editingAmount = subcontractor.Amount;
        editingNotes = subcontractor.Notes ?? string.Empty;
    }

    private void SaveSubcontractorEdit(int showSubcontractorId)
    {
        var subcontractor = Db.tShowSubcontractors.FirstOrDefault(ss => ss.ShowSubcontractorId == showSubcontractorId);
        if (subcontractor != null && editingAmount > 0)
        {
            subcontractor.Amount = editingAmount;
            subcontractor.Notes = editingNotes;
            subcontractor.UpdatedOn = DateTime.Now;
            Db.SaveChanges();
            LoadShowData();
            CancelEdit();
        }
    }

    private void CancelEdit()
    {
        editingSubcontractorId = 0;
        editingRole = string.Empty;
        editingAmount = 0;
        editingNotes = string.Empty;
    }

    private class ShowOption
    {
        public int ShowId { get; set; }
        public string DisplayText { get; set; } = string.Empty;
    }
}