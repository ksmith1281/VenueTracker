@page "/edit-show/{showId:int}"
@rendermode InteractiveServer

@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Navigation
@inject ILogger<EditShow> Logger

<PageTitle>Show Detail</PageTitle>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Show Detail</RadzenText>

@if (show == null)
{
    <RadzenText>Loading...</RadzenText>
}
else
{
    <RadzenCard class="rz-mb-4">
        <RadzenFormField Text="Show" class="rz-w-100 rz-mb-4">
            <RadzenDropDown TValue="int" Data="showOptions" TextProperty="DisplayText" ValueProperty="ShowId"
                            @bind-Value="selectedShowId" Change="OnShowChanged" Style="width: 100%;" />
        </RadzenFormField>

        <EditForm Model="@show" OnValidSubmit="@HandleValidSubmit" FormName="EditShowForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-4" Wrap="FlexWrap.Wrap">
                <RadzenFormField Text="Venue" Style="flex: 1;">
                    <RadzenText>@(show.tVenue?.VenueName) (@(show.tVenue?.City), @(show.tVenue?.State))</RadzenText>
                </RadzenFormField>
                <RadzenFormField Text="Status" Style="flex: 1;">
                    <RadzenText>@show.tStatus?.StatusName</RadzenText>
                </RadzenFormField>
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-4" Wrap="FlexWrap.Wrap">
                <RadzenFormField Text="Walk Amount" Style="flex: 1;">
                    <RadzenNumeric TValue="decimal" @bind-Value="show.WalkAmount" Format="C" Style="width: 100%;" />
                </RadzenFormField>
                <RadzenFormField Text="Payment Type" Style="flex: 1;">
                    <RadzenDropDown TValue="int?" Data="paymentTypes" TextProperty="PaymentType" ValueProperty="PaymentTypeId"
                                    @bind-Value="show.PaymentTypeId" Placeholder="Select payment type" Style="width: 100%;" />
                </RadzenFormField>
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-4" Wrap="FlexWrap.Wrap">
                <RadzenFormField Text="Merch Amount" Style="flex: 1;">
                    <RadzenNumeric TValue="decimal?" @bind-Value="show.MerchAmount" Format="C" Style="width: 100%;" />
                </RadzenFormField>
                <div style="flex: 1;"></div>
            </RadzenStack>

            <RadzenFormField Text="Deal" class="rz-w-100 rz-mb-4">
                <RadzenTextBox @bind-Value="show.Deal" Style="width: 100%;" />
            </RadzenFormField>

            <RadzenFormField Text="Notes" class="rz-w-100 rz-mb-4">
                <RadzenTextArea @bind-Value="show.Notes" Rows="3" Style="width: 100%;" />
            </RadzenFormField>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="8px">
                <RadzenButton ButtonType="ButtonType.Submit" Text="Save Changes" Icon="save" ButtonStyle="ButtonStyle.Primary" />
                <RadzenButton Text="Delete Show" Icon="delete" ButtonStyle="ButtonStyle.Danger" Click="DeleteShow" ButtonType="ButtonType.Button" />
                <RadzenButton Text="Cancel" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="Cancel" ButtonType="ButtonType.Button" />
            </RadzenStack>
        </EditForm>
    </RadzenCard>

    <RadzenCard>
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">Subcontractors</RadzenText>

        @if (showSubcontractors.Count > 0)
        {
            <RadzenDataGrid Data="showSubcontractors" TItem="tShowSubcontractor" class="rz-mb-4"
                            EditMode="DataGridEditMode.Single"
                            @ref="subcontractorGrid"
                            RowUpdate="OnSubcontractorRowUpdate">
                <Columns>
                    <RadzenDataGridColumn TItem="tShowSubcontractor" Title="Name">
                        <Template Context="sub">@sub.tSubcontractor?.Name</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="tShowSubcontractor" Title="Role">
                        <Template Context="sub">@sub.tSubcontractor?.Role</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="tShowSubcontractor" Property="Amount" Title="Amount" FormatString="{0:C}" />
                    <RadzenDataGridColumn TItem="tShowSubcontractor" Property="Notes" Title="Notes">
                        <EditTemplate Context="sub">
                            <RadzenTextBox @bind-Value="sub.Notes" Style="width: 100%;" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="tShowSubcontractor" Title="Actions" Width="140px">
                        <Template Context="sub">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                          Click="() => subcontractorGrid.EditRow(sub)" class="rz-mr-1" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                          Click="() => DeleteShowSubcontractor(sub.ShowSubcontractorId)" />
                        </Template>
                        <EditTemplate Context="sub">
                            <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small"
                                          Click="() => subcontractorGrid.UpdateRow(sub)" class="rz-mr-1" />
                            <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                          Click="() => subcontractorGrid.CancelEditRow(sub)" />
                        </EditTemplate>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }

        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-3">Add Subcontractor</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap" class="rz-mb-3">
            <RadzenFormField Text="Subcontractor" Style="flex: 1;">
                <RadzenDropDown TValue="int" Data="subcontractors" TextProperty="Name" ValueProperty="SubcontractorId"
                                @bind-Value="selectedSubcontractorId" Placeholder="Select subcontractor" Style="width: 100%;" />
            </RadzenFormField>
            <RadzenFormField Text="Amount" Style="flex: 1;">
                <RadzenNumeric TValue="decimal" @bind-Value="newSubcontractorAmount" Format="C" Style="width: 100%;" />
            </RadzenFormField>
            <RadzenFormField Text="Notes" Style="flex: 1;">
                <RadzenTextBox @bind-Value="newSubcontractorNotes" Style="width: 100%;" />
            </RadzenFormField>
        </RadzenStack>
        <RadzenButton Text="Add Subcontractor" Icon="add_circle" ButtonStyle="ButtonStyle.Success"
                      Click="AddSubcontractor"
                      Disabled="@(selectedSubcontractorId <= 0 || newSubcontractorAmount <= 0)" />
    </RadzenCard>
}

@code {
    [Parameter]
    public int ShowId { get; set; }

    private tShow? show;
    private List<tVenue> venues = new();
    private List<tStatus> statuses = new();
    private List<tPaymentType> paymentTypes = new();
    private List<tSubcontractor> subcontractors = new();
    private List<tShowSubcontractor> showSubcontractors = new();
    private List<ShowOption> showOptions = new();
    private RadzenDataGrid<tShowSubcontractor> subcontractorGrid = default!;

    private int selectedShowId
    {
        get => _selectedShowId;
        set
        {
            if (_selectedShowId != value)
            {
                _selectedShowId = value;
                LoadShowData();
            }
        }
    }

    private int _selectedShowId = 0;
    private int selectedSubcontractorId = 0;
    private decimal newSubcontractorAmount = 0;
    private string newSubcontractorNotes = string.Empty;

    protected override void OnInitialized()
    {
        LoadReferenceData();
    }

    protected override void OnParametersSet()
    {
        selectedShowId = ShowId;
        LoadShowData();
    }

    private void OnShowChanged(object value)
    {
        LoadShowData();
    }

    private void LoadReferenceData()
    {
        venues = Db.tVenues
            .Where(v => v.IsActive)
            .OrderBy(v => v.VenueName)
            .ToList();

        statuses = Db.tStatuses
            .OrderBy(s => s.StatusName)
            .ToList();

        paymentTypes = Db.tPaymentTypes
            .OrderBy(pt => pt.PaymentType)
            .ToList();

        subcontractors = Db.tSubcontractors
            .Where(s => s.IsActive)
            .OrderBy(s => s.Name)
            .ToList();

        showOptions = Db.tShows
            .OrderBy(s => s.ShowDate)
            .ThenBy(s => s.ShowName)
            .Select(s => new ShowOption
            {
                ShowId = s.ShowId,
                DisplayText = s.ShowDate.ToString("d") + " - " + (s.ShowName ?? string.Empty)
            })
            .ToList();
    }

    private void LoadShowData()
    {
        show = Db.tShows
            .Include(s => s.tVenue)
            .Include(s => s.tStatus)
            .Include(s => s.tPaymentType)
            .FirstOrDefault(s => s.ShowId == selectedShowId);

        if (show != null)
        {
            showSubcontractors = Db.tShowSubcontractors
                .Include(ss => ss.tSubcontractor)
                .Where(ss => ss.ShowId == selectedShowId)
                .ToList();
        }
    }

    private void HandleValidSubmit()
    {
        if (show == null) return;
        show.UpdatedOn = DateTime.Now;
        Db.SaveChanges();
        Navigation.NavigateTo("/");
    }

    private void DeleteShow()
    {
        if (show != null)
        {
            Db.tShows.Remove(show);
            Db.SaveChanges();
            Navigation.NavigateTo("/");
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/");
    }

    private void AddSubcontractor()
    {
        if (selectedSubcontractorId <= 0 || newSubcontractorAmount <= 0 || show == null) return;

        var newShowSubcontractor = new tShowSubcontractor
        {
            ShowId = show.ShowId,
            SubcontractorId = selectedSubcontractorId,
            Amount = newSubcontractorAmount,
            Notes = newSubcontractorNotes
        };

        Db.tShowSubcontractors.Add(newShowSubcontractor);
        Db.SaveChanges();

        LoadShowData();
        selectedSubcontractorId = 0;
        newSubcontractorAmount = 0;
        newSubcontractorNotes = string.Empty;
    }

    private void DeleteShowSubcontractor(int showSubcontractorId)
    {
        var subcontractor = Db.tShowSubcontractors.FirstOrDefault(ss => ss.ShowSubcontractorId == showSubcontractorId);
        if (subcontractor != null)
        {
            Db.tShowSubcontractors.Remove(subcontractor);
            Db.SaveChanges();
            LoadShowData();
        }
    }

    private void OnSubcontractorRowUpdate(tShowSubcontractor sub)
    {
        var existing = Db.tShowSubcontractors.FirstOrDefault(ss => ss.ShowSubcontractorId == sub.ShowSubcontractorId);
        if (existing != null && sub.Amount > 0)
        {
            existing.Amount = sub.Amount;
            existing.Notes = sub.Notes;
            existing.UpdatedOn = DateTime.Now;
            Db.SaveChanges();
            LoadShowData();
        }
    }

    private class ShowOption
    {
        public int ShowId { get; set; }
        public string DisplayText { get; set; } = string.Empty;
    }
}
