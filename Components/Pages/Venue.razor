@page "/venues"
@page "/venues/{venueId:int}"
@rendermode InteractiveServer

@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>@(venue.VenueId == 0 ? "Add Venue" : "Edit Venue")</PageTitle>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">@(venue.VenueId == 0 ? "Add Venue" : "Edit Venue")</RadzenText>

<RadzenCard class="rz-mb-4">
    <EditForm Model="@venue" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <RadzenFormField Text="Venue Name" class="rz-w-100 rz-mb-4">
            <RadzenTextBox @bind-Value="venue.VenueName" Style="width: 100%;" />
        </RadzenFormField>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-4" Wrap="FlexWrap.Wrap">
            <RadzenFormField Text="City" Style="flex: 1;">
                <RadzenTextBox @bind-Value="venue.City" Style="width: 100%;" />
            </RadzenFormField>
            <RadzenFormField Text="State" Style="flex: 1;">
                <RadzenTextBox @bind-Value="venue.State" Style="width: 100%;" />
            </RadzenFormField>
        </RadzenStack>

        <RadzenFormField Text="Capacity" class="rz-w-100 rz-mb-4">
            <RadzenNumeric TValue="int?" @bind-Value="venue.Capacity" Style="width: 100%;" />
        </RadzenFormField>

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" class="rz-mb-4">
            <RadzenCheckBox TValue="bool" @bind-Value="venue.IsActive" />
            <RadzenLabel Text="Is Active" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8px">
            <RadzenButton ButtonType="ButtonType.Submit" Text="@(venue.VenueId == 0 ? "Add Venue" : "Update Venue")"
                          Icon="save" ButtonStyle="ButtonStyle.Primary" />
            <RadzenButton Text="Cancel" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="Cancel" ButtonType="ButtonType.Button" />
        </RadzenStack>
    </EditForm>
</RadzenCard>

@if (venue.VenueId > 0)
{
    <RadzenCard class="rz-mb-4">
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">Buyers</RadzenText>

        @if (buyers.Count == 0)
        {
            <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-3">No buyers associated with this venue.</RadzenText>
        }
        else
        {
            <RadzenDataGrid Data="buyers" TItem="tBuyer" class="rz-mb-4">
                <Columns>
                    <RadzenDataGridColumn TItem="tBuyer" Title="Name">
                        <Template Context="b">@b.FirstName @b.LastName</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="tBuyer" Property="Email" Title="Email" />
                    <RadzenDataGridColumn TItem="tBuyer" Property="Phone" Title="Phone" />
                    <RadzenDataGridColumn TItem="tBuyer" Property="Cell" Title="Cell" />
                    <RadzenDataGridColumn TItem="tBuyer" Title="Active">
                        <Template Context="b">@(b.IsActive ? "Yes" : "No")</Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }

        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-3">Assign Existing Buyer</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.End" class="rz-mb-4" Wrap="FlexWrap.Wrap">
            <RadzenFormField Text="Buyer" Style="flex: 1;">
                <RadzenDropDown TValue="int" Data="availableBuyers" @bind-Value="selectedBuyerId"
                                TextProperty="DisplayName" ValueProperty="BuyerId"
                                Placeholder="Select buyer" Style="width: 100%;" />
            </RadzenFormField>
            <RadzenButton Text="Assign Buyer" Icon="person_add" ButtonStyle="ButtonStyle.Secondary" Click="AssignBuyer" />
        </RadzenStack>

        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-3">Add New Buyer</RadzenText>
        <EditForm Model="@newBuyer" OnValidSubmit="@HandleAddBuyer">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-4" Wrap="FlexWrap.Wrap">
                <RadzenFormField Text="First Name" Style="flex: 1;">
                    <RadzenTextBox @bind-Value="newBuyer.FirstName" Style="width: 100%;" />
                </RadzenFormField>
                <RadzenFormField Text="Last Name" Style="flex: 1;">
                    <RadzenTextBox @bind-Value="newBuyer.LastName" Style="width: 100%;" />
                </RadzenFormField>
            </RadzenStack>

            <RadzenFormField Text="Email" class="rz-w-100 rz-mb-4">
                <RadzenTextBox @bind-Value="newBuyer.Email" Style="width: 100%;" />
            </RadzenFormField>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-4" Wrap="FlexWrap.Wrap">
                <RadzenFormField Text="Phone" Style="flex: 1;">
                    <RadzenTextBox @bind-Value="newBuyer.Phone" Style="width: 100%;" />
                </RadzenFormField>
                <RadzenFormField Text="Cell" Style="flex: 1;">
                    <RadzenTextBox @bind-Value="newBuyer.Cell" Style="width: 100%;" />
                </RadzenFormField>
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" class="rz-mb-4">
                <RadzenCheckBox TValue="bool" @bind-Value="newBuyer.IsActive" />
                <RadzenLabel Text="Is Active" />
            </RadzenStack>

            <RadzenButton ButtonType="ButtonType.Submit" Text="Add Buyer" Icon="person_add" ButtonStyle="ButtonStyle.Primary" />
        </EditForm>
    </RadzenCard>
}

<RadzenCard>
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">Latest Added Venues</RadzenText>
    @if (recentVenues.Count == 0)
    {
        <RadzenText>No venues found.</RadzenText>
    }
    else
    {
        <RadzenDataGrid Data="recentVenues" TItem="tVenue" AllowSorting="true"
                        RowClick="OnRecentVenueRowClick"
                        Style="cursor: pointer;">
            <Columns>
                <RadzenDataGridColumn TItem="tVenue" Property="VenueName" Title="Venue Name" />
                <RadzenDataGridColumn TItem="tVenue" Property="City" Title="City" />
                <RadzenDataGridColumn TItem="tVenue" Property="State" Title="State" />
                <RadzenDataGridColumn TItem="tVenue" Property="Capacity" Title="Capacity" />
                <RadzenDataGridColumn TItem="tVenue" Title="Active">
                    <Template Context="v">@(v.IsActive ? "Yes" : "No")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="tVenue" Property="CreatedOn" Title="Added On" FormatString="{0:d}" />
            </Columns>
        </RadzenDataGrid>
    }
</RadzenCard>

@code {
    [Parameter]
    public int? VenueId { get; set; }

    private tVenue venue = new() { IsActive = true };
    private List<tBuyer> buyers = new();
    private List<BuyerOption> availableBuyers = new();
    private tBuyer newBuyer = new() { IsActive = true };
    private int selectedBuyerId = 0;
    private List<tVenue> recentVenues = new();

    protected override void OnInitialized()
    {
        if (VenueId.HasValue)
        {
            LoadVenue(VenueId.Value);
            LoadBuyers();
        }
        LoadAvailableBuyers();
        LoadRecentVenues();
    }

    private void LoadVenue(int id)
    {
        venue = Db.tVenues.Find(id) ?? new tVenue { IsActive = true };
    }

    private void LoadBuyers()
    {
        if (venue.VenueId > 0)
        {
            buyers = Db.tBuyers
                .Where(b => b.VenueId == venue.VenueId)
                .OrderBy(b => b.LastName)
                .ThenBy(b => b.FirstName)
                .ToList();
        }
    }

    private void LoadAvailableBuyers()
    {
        availableBuyers = Db.tBuyers
            .Where(b => b.VenueId == null)
            .OrderBy(b => b.LastName)
            .ThenBy(b => b.FirstName)
            .Select(b => new BuyerOption
            {
                BuyerId = b.BuyerId,
                DisplayName = b.FirstName + " " + b.LastName + " (" + b.Email + ")"
            })
            .ToList();
    }

    private void LoadRecentVenues()
    {
        recentVenues = Db.tVenues
            .OrderByDescending(v => v.CreatedOn)
            .Take(10)
            .ToList();
    }

    private void HandleValidSubmit()
    {
        if (venue.VenueId == 0)
        {
            venue.CreatedOn = DateTime.Now;
            Db.tVenues.Add(venue);
        }
        venue.UpdatedOn = DateTime.Now;
        Db.SaveChanges();

        if (VenueId == null)
        {
            Navigation.NavigateTo($"/venues/{venue.VenueId}");
        }
        else
        {
            LoadBuyers();
            LoadAvailableBuyers();
            LoadRecentVenues();
            StateHasChanged();
        }
    }

    private void HandleAddBuyer()
    {
        newBuyer.VenueId = venue.VenueId;
        newBuyer.CreatedOn = DateTime.Now;
        newBuyer.UpdatedOn = DateTime.Now;
        Db.tBuyers.Add(newBuyer);
        Db.SaveChanges();

        newBuyer = new tBuyer { IsActive = true };
        LoadBuyers();
        LoadAvailableBuyers();
        StateHasChanged();
    }

    private void AssignBuyer()
    {
        if (selectedBuyerId > 0)
        {
            var buyer = Db.tBuyers.Find(selectedBuyerId);
            if (buyer != null)
            {
                buyer.VenueId = venue.VenueId;
                buyer.UpdatedOn = DateTime.Now;
                Db.SaveChanges();
                LoadBuyers();
                LoadAvailableBuyers();
                selectedBuyerId = 0;
                StateHasChanged();
            }
        }
    }

    private void OnRecentVenueRowClick(DataGridRowMouseEventArgs<tVenue> args)
    {
        if (args.Data != null) EditVenue(args.Data.VenueId);
    }

    private void EditVenue(int venueId)
    {
        Navigation.NavigateTo($"/venues/{venueId}");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/venues");
    }

    private class BuyerOption
    {
        public int BuyerId { get; set; }
        public string DisplayName { get; set; } = string.Empty;
    }
}
