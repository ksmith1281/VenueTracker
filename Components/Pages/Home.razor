@page "/"
@using VenueTracker.Data
@using VenueTracker.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<PageTitle>Home</PageTitle>

<h1>Track a Show</h1>
<p>Use this form to add a new show and its walk details. Or <a href="/add-show">add a simple show</a>.</p>

<EditForm Model="@currentShow" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="venue" class="form-label">Venue</label>
        <select id="venue" class="form-select" @bind="currentShow.VenueId">
            <option value="0">Select venue</option>
            @foreach (var venue in venues)
            {
                <option value="@venue.VenueId">@venue.VenueName (@venue.City, @venue.State)</option>
            }
        </select>
        <ValidationMessage For="@(() => currentShow.VenueId)" />
    </div>

    <div class="mb-3">
        <label for="showDate" class="form-label">Show Date</label>
        <InputDate id="showDate" class="form-control" @bind-Value="currentShow.ShowDate" />
        <ValidationMessage For="@(() => currentShow.ShowDate)" />
    </div>

    <div class="mb-3">
        <label for="showName" class="form-label">Show Name</label>
        <InputText id="showName" class="form-control" @bind-Value="currentShow.ShowName" />
    </div>

    <div class="mb-3">
        <label for="walkAmount" class="form-label">Walk Amount</label>
        <InputNumber id="walkAmount" class="form-control" @bind-Value="currentShow.WalkAmount" />
    </div>

    <div class="mb-3">
        <label for="merchAmount" class="form-label">Merch Amount</label>
        <InputNumber id="merchAmount" class="form-control" @bind-Value="currentShow.MerchAmount" />
    </div>

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea id="notes" class="form-control" @bind-Value="currentShow.Notes" />
    </div>

    <button type="submit" class="btn btn-primary">Add Show</button>
</EditForm>

<hr />

<h2>Upcoming Shows</h2>
@if (upcomingShows.Count == 0)
{
    <p>No upcoming shows found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ShowId</th>
                <th>Venue</th>
                <th>Date</th>
                <th>Name</th>
                <th>Status</th>
                <th>Walk</th>
                <th>Merch</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in upcomingShows)
            {
                <tr>
                    <td>@row.ShowId</td>
                    <td>@row.VenueName</td>
                    <td>@row.ShowDate.ToShortDateString()</td>
                    <td>@row.ShowName</td>
                    <td>@row.StatusName</td>
                    <td>@row.WalkAmount</td>
                    <td>@row.MerchAmount</td>
                    <td>@row.Notes</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private tShow currentShow = new() { ShowDate = DateTime.Today };
    private List<tVenue> venues = new();
    private List<UpcomingShowView> upcomingShows = new();

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        venues = Db.tVenues
            .Where(v => v.IsActive)
            .OrderBy(v => v.VenueName)
            .ToList();

        upcomingShows = Db.tShows
            .Include(s => s.tVenue)
            .Include(s => s.tStatus)
            .Where(s => s.ShowDate >= DateTime.Today)
            .OrderBy(s => s.ShowDate)
            .Select(s => new UpcomingShowView
            {
                ShowId = s.ShowId,
                VenueName = s.tVenue!.VenueName,
                ShowDate = s.ShowDate,
                ShowName = s.ShowName,
                WalkAmount = s.WalkAmount,
                MerchAmount = s.MerchAmount,
                Notes = s.Notes,
                StatusName = s.tStatus!.StatusName
            })
            .ToList();
    }

    private void HandleValidSubmit()
    {
        if (currentShow.VenueId <= 0)
        {
            return;
        }

        currentShow.CreatedOn = DateTime.Now;
        currentShow.UpdatedOn = DateTime.Now;

        Db.tShows.Add(currentShow);
        Db.SaveChanges();

        LoadData();
        ResetForm();
    }

    private void ResetForm()
    {
        currentShow = new tShow { ShowDate = DateTime.Today };
    }

    private class UpcomingShowView
    {
        public int ShowId { get; set; }
        public string? VenueName { get; set; }
        public DateTime ShowDate { get; set; }
        public string? ShowName { get; set; }
        public decimal WalkAmount { get; set; }
        public decimal? MerchAmount { get; set; }
        public string? Notes { get; set; }
        public string? StatusName { get; set; }
    }
}
