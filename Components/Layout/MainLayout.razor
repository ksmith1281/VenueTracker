@inherits LayoutComponentBase

<RadzenLayout Style="min-height: 100vh;">

    <RadzenSidebar @bind-Expanded="sidebarOpen" Responsive="false" Style="width: 250px;">
        <NavMenu />
    </RadzenSidebar>

    <RadzenHeader Style="display: flex; align-items: center; gap: 1rem; padding: 0 1rem;">
        <RadzenButton Icon="menu" ButtonStyle="ButtonStyle.Light" Click="@ToggleSidebar"
                      aria-label="Toggle navigation" />

        <div style="flex: 1;">
            <ShowSearchBar />
        </div>
    </RadzenHeader>

    <RadzenBody Style="padding: 1rem;">
        @Body
    </RadzenBody>

</RadzenLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool sidebarOpen = true;

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }
}