@inherits LayoutComponentBase

<MudThemeProvider />
<MudSnackbarProvider />

<div class="page @(sidebarOpen ? string.Empty : "sidebar-closed")">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <button class="menu-button" @onclick="ToggleSidebar" aria-label="Toggle navigation">☰</button>
            <div class="search-wrapper">
                <ShowSearchBar />
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool sidebarOpen = true;

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }
}
