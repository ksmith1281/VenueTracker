@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using VenueTracker.Data
@using VenueTracker.Models
@inject AppDbContext Db
@inject NavigationManager Navigation

<div class="show-search-bar mb-3 position-relative">
    <label class="form-label mb-1" for="showSearchInput">Search shows</label>
    <input id="showSearchInput" class="form-control" placeholder="Search by show name, venue, or deal..." value="@query"
           @oninput="OnQueryChanged" />

    @if (searchResults?.Count > 0)
    {
        <ul class="list-group position-absolute w-100 shadow-sm"
            style="z-index: 1000; max-height: 240px; overflow-y: auto;">
            @foreach (var result in searchResults)
            {
                <li class="list-group-item list-group-item-action" @onclick="() => SelectShow(result.ShowId)">
                    <strong>@result.DisplayText</strong>
                    <div class="text-muted small">@result.Subtitle</div>
                </li>
            }
        </ul>
    }
</div>

@code {
    private string query = string.Empty;
    private List<ShowSearchResult> searchResults = new();

    private void SelectShow(int showId)
    {
        query = string.Empty;
        searchResults.Clear();
        Navigation.NavigateTo($"/edit-show/{showId}");
    }

    private void OnQueryChanged(ChangeEventArgs args)
    {
        query = args?.Value?.ToString() ?? string.Empty;
        UpdateSearchResults();
    }

    private void UpdateSearchResults()
    {
        var trimmed = query?.Trim();
        if (string.IsNullOrWhiteSpace(trimmed) || trimmed.Length < 2)
        {
            searchResults.Clear();
            return;
        }

        var searchTerm = trimmed.ToLower();

        searchResults = Db.tShows
            .Include(s => s.tVenue)
            .Where(s =>
                (!string.IsNullOrEmpty(s.ShowName) && s.ShowName.ToLower().Contains(searchTerm)) ||
                (!string.IsNullOrEmpty(s.Deal) && s.Deal.ToLower().Contains(searchTerm)) ||
                (s.tVenue != null && !string.IsNullOrEmpty(s.tVenue.VenueName) && s.tVenue.VenueName.ToLower().Contains(searchTerm)) ||
                (s.tVenue != null && !string.IsNullOrEmpty(s.tVenue.City) && s.tVenue.City.ToLower().Contains(searchTerm))
            )
            .OrderByDescending(s => s.ShowDate)
            .Take(8)
            .Select(s => new ShowSearchResult
            {
                ShowId = s.ShowId,
                DisplayText = (s.ShowName ?? $"Show on {s.ShowDate:d}") + " - " + (s.tVenue != null ? s.tVenue.VenueName : "Unknown venue"),
                Subtitle = s.tVenue != null ? $"{s.ShowDate:d} · {s.tVenue.City}, {s.tVenue.State}" : $"{s.ShowDate:d}"
            })
            .ToList();
    }

    private class ShowSearchResult
    {
        public int ShowId { get; set; }
        public string DisplayText { get; set; } = string.Empty;
        public string Subtitle { get; set; } = string.Empty;
    }
}
